# Copy this file to .env and fill in real values before running docker compose.
# .env is git-ignored — never commit it.

# ── PostgreSQL ───────────────────────────────────────────────────────────────
DB_PASSWORD=change_me

# ── JWT signing secret ────────────────────────────────────────────────────────
# Must be at least 64 characters for HS256. Generate one with:
#   openssl rand -hex 64
JWT_SECRET_KEY=change_me_generate_with_openssl_rand_hex_64

# ── Gmail App Password ────────────────────────────────────────────────────────
# Google Account → Security → 2-Step Verification → App passwords
MAIL_PASSWORD=change_me

# ── CORS ─────────────────────────────────────────────────────────────────────
# Frontend origin that is allowed to call the backend API.
CORS_ALLOWED_ORIGINS=https://priyanshu-portfolio.dev

# ── Frontend port (optional, defaults to 80) ─────────────────────────────────
# FRONTEND_PORT=80
